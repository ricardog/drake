;;; tests/advanced-facet-tests.el --- Advanced tests for native faceting -*- lexical-binding: t; -*-

(require 'test-helper)
(require 'drake)
(require 'drake-gnuplot)
(require 'drake-rust)
(require 'drake-svg)

;;; Faceting with different plot types

(ert-deftest drake-facet-with-line-plots ()
  "Test faceting with line plots."
  (let* ((data '(:x [1 2 3 1 2 3]
                 :y [10 20 30 15 25 35]
                 :category ["A" "A" "A" "B" "B" "B"]))
         (fplot (drake-facet :data data :col :category
                            :plot-fn #'drake-plot-line
                            :args '(:x :x :y :y)
                            :backend 'svg)))
    (should (drake-facet-plot-p fplot))
    (should (= (drake-facet-plot-cols fplot) 2))
    (should (drake-facet-plot-image fplot))))

(ert-deftest drake-facet-with-bar-plots ()
  "Test faceting with bar plots."
  (let* ((data '(:x ["X" "Y" "X" "Y"]
